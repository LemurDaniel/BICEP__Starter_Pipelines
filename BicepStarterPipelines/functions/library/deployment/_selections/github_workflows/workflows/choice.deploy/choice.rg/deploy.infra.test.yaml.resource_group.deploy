    
name: Test | Deploy Infrastructure

on:
  workflow_dispatch:
    inputs:
      what_if_only:
        description: Run a what-if analysis without making changes
        type: boolean
        default: true

  push:
    branches:
      - dev
    paths:
      - 'main.bicep'
      - 'params/main.test.bicep'

  pull_request:
    branches:
      - dev
    paths:
      - 'main.bicep'
      - 'params/main.test.bicep'
   
jobs:
  deploy_test:
    name: Deploy Infrastructure Test
    uses: ./.github/workflows/tmpl.bicep.infra.deploy.yaml
    #
    # Set a secret named AZURE_CICDSPN either:
    # - in the environment
    # - or repository scoped
    #
    # The secret should be jsonencoded like this:
    # {
    #   "clientId": "00000000-0000-0000-0000-000000000000",
    #   "objectId": "00000000-0000-0000-0000-000000000000",
    #   "clientSecret": "00000000-0000-0000-0000-000000000000",
    #   "subscriptionId": "00000000-0000-0000-0000-000000000000",
    #   "tenantId": "00000000-0000-0000-0000-000000000000"
    # }
    secrets: inherit
    with:
      environment: test
      # NOTE:
      # You can add an approval gate via the environment deployment protection rule for approvers
      # environment: test
      scope: resource_group
      resource_group: 'rg-sample-test'
      
      deployment_name: 'sample-test'
      template_file: ./main.bicep
      parameter_file: ./params/main.test.bicepparam
      
      what_if_only: ${{ github.EVENT_NAME  == 'pull_request' || inputs.what_if_only == true }}

      # set_temporary_ip_rules: |
      #   acr-sample-test