{
    // See https://go.microsoft.com/fwlink/?LinkId=733558
    // for the documentation about the tasks.json format
    "version": "2.0.0",
    "tasks": [
        {
            "label": "[Test] Run Pester",
            "type": "shell",
            "command": "Invoke-Pester",
            "args": [
                "-Path",
                "${file}",
                "-Output",
                "Detailed"
            ],
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared",
                "showReuseMessage": true,
                "clear": false,
                "close": false
            },
            "options": {
                "shell": {
                    "executable": "pwsh.exe",
                    "args": [
                        "-NoProfile",
                        "-ExecutionPolicy",
                        "Bypass",
                        "-Command"
                    ]
                }
            },
            "problemMatcher": []
        },
        {
            "label": "[Generate] Examples Script",
            "type": "shell",
            "command": "pwsh",
            "args": [
                "-NoProfile",
                "-File",
                "'${workspaceFolder}/.vscode/generate.examples.ps1'",
                "-WorkingDirectory",
                "'${workspaceFolder}'"
            ],
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared",
                "showReuseMessage": true,
                "clear": false,
                "close": false
            },
            "problemMatcher": []
        }
    ]
}
