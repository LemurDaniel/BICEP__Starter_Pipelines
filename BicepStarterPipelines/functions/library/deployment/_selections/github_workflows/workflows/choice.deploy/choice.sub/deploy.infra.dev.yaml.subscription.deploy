    
name: Dev | Deploy Infrastructure

on:
  workflow_dispatch:
    inputs:
      what_if_only:
        description: Run a what-if analysis without making changes
        type: boolean
        default: true

#  Execution only on workflow dispatch
#  push:
#    branches:
#      - dev
#    paths:
#      - 'main.bicep'
#      - 'params/main.test.bicep'
#
#  pull_request:
#    branches:
#      - dev
#    paths:
#      - 'main.bicep'
#      - 'params/main.test.bicep'
   
jobs:
  deploy_dev:
    name: Deploy Infrastructure Dev
    uses: ./.github/workflows/tmpl.bicep.infra.deploy.yaml
    #
    # Define following Secrets either:
    # - in the environment
    # - or repository scoped
    #
    # When Auth_type: OIDC (Workload Identity Federation)
    # AZURE_AUTH = {
    #   "auth_type": "OIDC",
    #   "tenantId": "00000000-0000-0000-0000-000000000000",
    #   "subscriptionId": "00000000-0000-0000-0000-000000000000",
    #   "clientId": "00000000-0000-0000-0000-000000000000"
    # }
    # Either:
    # - Federated Credential on User Managed Identity: https://learn.microsoft.com/en-us/entra/workload-id/workload-identity-federation-create-trust-user-assigned-managed-identity?pivots=identity-wif-mi-methods-azp#configure-a-federated-identity-credential-on-a-user-assigned-managed-identity
    # - Federated Credential on App Registration: https://learn.microsoft.com/en-us/entra/workload-id/workload-identity-federation-create-trust?pivots=identity-wif-apps-methods-azp#github-actions
    #
    # When Auth_type: ClientSecret
    # AZURE_AUTH = {
    #   "auth_type": "ClientSecret",
    #   "tenantId": "00000000-0000-0000-0000-000000000000",
    #   "subscriptionId": "00000000-0000-0000-0000-000000000000",
    #   "clientId": "00000000-0000-0000-0000-000000000000",
    #   "clientSecret": "00000000-0000-0000-0000-000000000000"
    # }
    secrets: inherit
    with:
      # environment: dev
      
      scope: subscription
      location: germanywestcentral

      deployment_name: 'sample-dev'
      template_file: ./main.bicep
      parameter_file: ./params/main.dev.bicepparam

      what_if_only: ${{ github.EVENT_NAME  == 'pull_request' || inputs.what_if_only == true }}

      # set_temporary_ip_rules: |
      #   acrsampledev