    
name: Deploy Infrastructure Dev / Test

on:
  workflow_dispatch:
    inputs:
      what_if_only:
        type: boolean
        default: true

  push:
    branches:
      - dev
    paths:
      - 'main.bicep'
      - './params/main.dev.bicepparam'
      - './params/main.test.bicepparam'

  pull_request:
    branches:
      - dev
    paths:
      - 'main.bicep'
      - './params/main.dev.bicepparam'
      - './params/main.test.bicepparam'
   
jobs:
  deploy_dev:
    name: Deploy Infrastructure Dev
    uses: ./.github/workflows/tmpl.deploy.infrastructure.yaml
    secrets:
      AZURE_DEPLOYMENT_SPN: ${{ secrets.AZURE_CICDSPN }}
    with:
      scope: resourceGroup
      resource_group: 'sample-dev'

      name: 'sample-dev'
      template_file: ./main.bicep
      parameter_file: ./params/main.dev.bicepparam
      what_if_only: ${{ github.EVENT_NAME  == 'pull_request' || inputs.what_if_only == true }}
      what_if_artifact_name: what_if_result_dev

  deploy_test:
    needs:
    - deploy_dev
    name: Deploy Infrastructure Test
    uses: ./.github/workflows/tmpl.deploy.infrastructure.yaml
    secrets:
      AZURE_DEPLOYMENT_SPN: ${{ secrets.AZURE_CICDSPN }}
    with:
      scope: resourceGroup
      resource_group: 'sample-test'

      name: 'sample-test'
      template_file: ./main.bicep
      parameter_file: ./params/main.test.bicepparam
      what_if_only: ${{ github.EVENT_NAME  == 'pull_request' || inputs.what_if_only == true }}
      what_if_artifact_name: what_if_result_test