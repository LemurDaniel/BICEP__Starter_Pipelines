parameters:
  - name: condition
    type: string
    default: true
  - name: stage
    type: string
  - name: displayName
    type: string
    default: ''
  - name: serviceConnection
    type: string
  - name: variableGroup
    type: string
    default: ''

  # General deployment parameter
  - name: deploymentName
    type: string
  - name: templateFile
    type: string
  - name: parametersFile
    type: string
  - name: WhatIfOnly
    type: string
    default: true
  - name: WhatIfResultFormat
    type: string
    default: 'FullResourcePayloads' # ResourceIdOnly | FullResourcePayloads
  - name: WhatIfExcludeChange
    type: string
    default: '' # Ignore | NoChange | Deploy | Create | Modify | Delete

  # deployment scope
  - name: scope
    type: string
    # subscription | resourceGroup

  # deployment specific parameters
  - name: subscriptionId
    type: string
    default: ''
  - name: location
    type: string
    default: ''
  - name: resourceGroup
    type: string
    default: ''

  # others
  - name: showTree
    type: boolean
    default: false
  - name: runBicepTests
    type: boolean
    default: false
  - name: azurePowerShellVersion
    type: string
    default: LatestVersion

stages:
  - stage: ${{ parameters.stage }}
    condition: ${{ parameters.condition }}
    ${{ if eq(parameters.displayName, '') }}:
      displayName: Deploy Bicep ${{ parameters.stage }}
    ${{ if ne(parameters.displayName, '') }}:
      displayName: ${{ parameters.displayName }}

    variables:
      - ${{ if ne(parameters.variableGroup, '') }}:
          - group: ${{ parameters.variableGroup }}
    jobs:
      #////////////////////////////////////////////////////////////
      #////// WhatIf
      - deployment: what_if_${{ parameters.stage }}
        displayName: WhatIf Bicep ${{ parameters.stage }}
        environment: ${{ parameters.stage }}
        strategy:
          runOnce:
            deploy:
              steps:
                - checkout: self
                - ${{ each subModule in parameters.checkoutSubModules }}:
                    - checkout: ${{ subModule.alias }}
                      path: s/$(Build.Repository.Name)/${{ subModule.path }}
                #////////////////////////////////////////////////////////////
                #////// Tree Command
                - script: |
                    sudo apt-get update
                    sudo apt-get install -y tree
                  displayName: Install tree
                  condition: ${{ parameters.showTree }}
                - script: |
                    tree $(Build.SourcesDirectory)
                  condition: ${{ parameters.showTree }}
                  displayName: Show directory
                #////////////////////////////////////////////////////////////
                #////// Bicep Tests
                - task: AzurePowerShell@5
                  condition: eq(${{ parameters.runBicepTests }}, true)
                  displayName: Bicep Test ${{ parameters.stage }}
                  inputs:
                    azureSubscription: ${{ parameters.serviceConnection }}
                    azurePowerShellVersion: ${{ parameters.azurePowerShellVersion }}
                    ScriptType: inlineScript
                    pwsh: true
                    inline: |
                      $testFiles = Get-ChildItem -Path "$(Build.SourcesDirectory)" -Filter *test.bicep -Recurse -Depth 4
                      foreach($file in $testFiles) {
                        bicep test $file.FullName
                      }
                #////////////////////////////////////////////////////////////
                #////// WhatIf
                - task: AzurePowerShell@5
                  displayName: WhatIf Bicep ${{ parameters.stage }}
                  inputs:
                    azureSubscription: ${{ parameters.serviceConnection }}
                    azurePowerShellVersion: ${{ parameters.azurePowerShellVersion }}
                    ScriptType: inlineScript
                    pwsh: true
                    inline: |
                        if(-NOT [System.String]::IsNullOrEmpty('${{ parameters.subscriptionId }}')) {
                           Write-Host 'Subscription: ${{ parameters.subscriptionId }}'
                           Set-AzContext -Subscription ${{ parameters.subscriptionId }}
                        }

                        $Deployment = @{
                            Name                    = '${{ parameters.deploymentName }}'
                            TemplateFile            = '${{ parameters.templateFile }}'
                            TemplateParameterFile   = '${{ parameters.parametersFile }}'
                            WhatIf                  = $true
                            WhatIfResultFormat      = '${{ parameters.WhatIfResultFormat }}'
                        }

                        if(-NOT [System.String]::IsNullOrEmpty('${{ parameters.WhatIfExcludeChange }}')) {
                            $Deployment.Add('WhatIfExcludeChangeType', '${{ parameters.WhatIfExcludeChange }}')
                        }


                        $workingDir = '$(Build.SourcesDirectory)/$(Build.Repository.Name)'

                        $Deployment['TemplateFile']          = "$workingDir/$($Deployment['TemplateFile'])"
                        $Deployment['TemplateParameterFile'] = "$workingDir/$($Deployment['TemplateParameterFile'])"

                        if('${{ parameters.scope }}' -EQ 'subscription') {
                          if([System.String]::IsNullOrEmpty('${{ parameters.location }}')) {
                            throw "Subscription Deployment needs a location!"
                          }

                          $Deployment.Add('location', '${{ parameters.location }}')

                          Start-Transcript -Path "$(Build.ArtifactStagingDirectory)/bicep_whatif.txt"
                          New-AzSubscriptionDeployment @Deployment
                          Stop-Transcript
                        } 
                        elseif('${{ parameters.scope }}' -EQ 'resourceGroup') {
                          if([System.String]::IsNullOrEmpty('${{ parameters.resourceGroup }}')) {
                            throw "Resource Group Deployment needs a resource group!"
                          }

                          $Deployment.Add('ResourceGroupName', '${{ parameters.resourceGroup }}')

                          Start-Transcript -Path "$(Build.ArtifactStagingDirectory)/bicep_whatif.txt"
                          New-AzResourceGroupDeployment @Deployment
                          Stop-Transcript
                        } else {
                          throw "Invalid Scope ${{ parameters.scope }}!"
                        }

                - task: PublishBuildArtifacts@1
                  displayName: "Bicep WhatIf Artifact"
                  inputs:
                    targetPath: "$(Build.ArtifactStagingDirectory)/bicep_whatif.txt"
                    artifactName: "bicep_whatif_${{ parameters.stage }}"

      - job: approve_${{ parameters.stage }}
        condition: and(succeeded(), eq(${{ parameters.WhatIfOnly }}, false))
        dependsOn: what_if_${{ parameters.stage }}
        displayName: Approve
        pool: server
        steps:
          - task: ManualValidation@0
            displayName: Manual Validation
            timeoutInMinutes: 1440

      #////////////////////////////////////////////////////////////
      #////// Deploy
      - deployment: deployment_${{ parameters.stage }}
        condition: and(succeeded(), eq(${{ parameters.WhatIfOnly }}, false))
        dependsOn: approve_${{ parameters.stage }}
        displayName: Deploy Bicep ${{ parameters.stage }}
        environment: ${{ parameters.stage }}
        strategy:
          runOnce:
            deploy:
              steps:
                - checkout: self
                - ${{ each subModule in parameters.checkoutSubModules }}:
                    - checkout: ${{ subModule.alias }}
                      path: s/$(Build.Repository.Name)/${{ subModule.path }}
                - task: AzurePowerShell@5
                  displayName: WhatIf Bicep ${{ parameters.stage }}
                  inputs:
                    azureSubscription: ${{ parameters.serviceConnection }}
                    azurePowerShellVersion: ${{ parameters.azurePowerShellVersion }}
                    ScriptType: inlineScript
                    pwsh: true
                    inline: |
                        if(-NOT [System.String]::IsNullOrEmpty('${{ parameters.subscriptionId }}')) {
                           Write-Host 'Subscription: ${{ parameters.subscriptionId }}'
                           Set-AzContext -Subscription ${{ parameters.subscriptionId }}
                        }

                        $Deployment = @{
                            Name                    = '${{ parameters.deploymentName }}'
                            TemplateFile            = '${{ parameters.templateFile }}'
                            TemplateParameterFile   = '${{ parameters.parametersFile }}'
                        }

                        $workingDir = '$(Build.SourcesDirectory)/$(Build.Repository.Name)'

                        $Deployment['TemplateFile']          = "$workingDir/$($Deployment['TemplateFile'])"
                        $Deployment['TemplateParameterFile'] = "$workingDir/$($Deployment['TemplateParameterFile'])"

                        if('${{ parameters.scope }}' -EQ 'subscription') {
                          if([System.String]::IsNullOrEmpty('${{ parameters.location }}')) {
                            throw "Subscription Deployment needs a location!"
                          }

                          $Deployment.Add('location', '${{ parameters.location }}')

                          New-AzSubscriptionDeployment @Deployment -Verbose
                        } 
                        elseif('${{ parameters.scope }}' -EQ 'resourceGroup') {
                          if([System.String]::IsNullOrEmpty('${{ parameters.resourceGroup }}')) {
                            throw "Resource Group Deployment needs a resource group!"
                          }

                          $Deployment.Add('ResourceGroupName', '${{ parameters.resourceGroup }}')

                          New-AzResourceGroupDeployment @Deployment -Verbose
                        } else {
                          throw "Invalid Scope ${{ parameters.scope }}!"
                        }
