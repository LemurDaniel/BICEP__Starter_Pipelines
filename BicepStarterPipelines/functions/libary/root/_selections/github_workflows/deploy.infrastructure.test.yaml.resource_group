    
name: Deploy Infrastructure PreProd

on:
  workflow_dispatch:
    inputs:
      what_if_only:
        type: boolean
        default: true

  push:
    branches:
      - master
    paths:
      - 'main.bicep'
      - './params/main.test.bicep'

  pull_request:
    branches:
      - master
      - dev
    paths:
      - 'main.bicep'
      - './params/main.test.bicep'
   
jobs:
  deploy_test:
    name: Deploy Infrastructure Test
    uses: ./.github/workflows/tmpl.deploy.infrastructure.yaml
    secrets:
      AZURE_DEPLOYMENT_SPN: ${{ secrets.AZURE_CICDSPN }}
    with:
      # NOTE:
      # You can add an approval gate via the environment deployment protection rule for approvers
      # environment: test
      scope: resourceGroup
      resource_group: 'sample-test'
      
      name: 'sample-test'
      template_file: ./main.bicep
      parameter_file: ../params/main.test.bicepparam
      what_if_only: ${{ github.EVENT_NAME  == 'pull_request' || inputs.what_if_only == true }}
      what_if_artifact_name: what_if_result