    
name: Deploy Infrastructure PreProd

on:
  workflow_dispatch:
    inputs:
      what_if_only:
        type: boolean
        default: true

      deny_settings_mode:
        type: string
        default: denyDelete
        options:
          - none
          - denyDelete
          - denyWriteAndDelete
      action_on_unmanage:
        type: string
        default: detachAll
        options:
          - deleteAll
          - detachAll
          - deleteResources

  push:
    branches:
      - dev
    paths:
      - 'main.bicep'
      - './params/main.test.bicep'

  pull_request:
    branches:
      - dev
    paths:
      - 'main.bicep'
      - './params/main.test.bicep'
   
jobs:
  deploy_test:
    name: Deploy Infrastructure Test
    uses: ./.github/workflows/tmpl.deploy.infrastructure.yaml
    secrets:
      AZURE_DEPLOYMENT_SPN: ${{ secrets.AZURE_CICDSPN }}
    with:
      # NOTE:
      # You can add an approval gate via the environment deployment protection rule for approvers
      # environment: test
      scope: subscription
      location: germanywestcentral
      
      name: 'sample-test'
      template_file: ./main.bicep
      parameter_file: ../params/main.test.bicepparam

      action_on_unmanage: ${{ inputs.action_on_unmanage }}
      deny_settings_mode: ${{ inputs.deny_settings_mode }}
      
      what_if_only: ${{ github.EVENT_NAME  == 'pull_request' || inputs.what_if_only == true }}